# --- CORS / API base ---
# Leave VITE_API_BASE_URL unset (or empty) while using `npm run dev` or `npm run preview`:
# the app calls same-origin `/api/...` and Vite proxies to the real backend (no browser CORS).

# Full API URL for production builds when the SPA is hosted on a different domain than the API.
# VITE_API_BASE_URL=https://backendclientapi.onrender.com

# Where Vite should forward `/api` in dev/preview (defaults to Render URL if unset).
# VITE_API_PROXY_TARGET=https://backendclientapi.onrender.com
# VITE_API_PROXY_TARGET=http://127.0.0.1:8080
